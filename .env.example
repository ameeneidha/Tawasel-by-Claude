# Database
DATABASE_URL="file:./dev.db"

# Superadmin (SaaS owner email - gets access to platform admin dashboard)
SUPERADMIN_EMAIL="your-email@example.com"
VITE_SUPERADMIN_EMAIL="your-email@example.com"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenAI
OPENAI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Meta (WhatsApp/Instagram)
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=
META_APP_ID=
META_EMBEDDED_SIGNUP_CONFIG_ID=
META_GRAPH_VERSION=v22.0
META_PHONE_NUMBER_ID=
META_WABA_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCOUNT_ID=
INSTAGRAM_ACCESS_TOKEN=

# JWT
JWT_SECRET=replace-with-a-random-64-char-hex-secret

# Email delivery (optional)
RESEND_API_KEY=
EMAIL_FROM=

# If true, local development can still show preview links when email delivery is missing or fails.
ALLOW_EMAIL_LINK_PREVIEW=true

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PUBLIC_APP_URL: The public dashboard URL, for example https://app.tawasel.io
PUBLIC_APP_URL=

# API_URL: The public backend/API URL, for example https://api.tawasel.io
API_URL=

# ALLOWED_ORIGINS: Comma-separated browser origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend runtime URLs
VITE_PUBLIC_APP_URL=
VITE_API_BASE_URL=
VITE_SOCKET_URL=

# If true, the app seeds demo data only when the database is empty on boot.
AUTO_SEED_DEMO=false
